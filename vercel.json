{
  "version": 2,
  "outputDirectory": "smart-expense-tracker/frontend",
  "builds": [
    {
      "src": "smart-expense-tracker/backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "smart-expense-tracker/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/smart-expense-tracker/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/smart-expense-tracker/frontend/$1"
    }
  ]
}